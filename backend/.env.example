# ── Server ──────────────────────────────────────────
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# ── Database ────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/campunity

# ── Auth (REQUIRED: JWT_SECRET must be ≥16 chars) ──
JWT_SECRET=your-minimum-16-char-secret

# ── Email (optional — leave blank to disable) ───────
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=you@example.com
EMAIL_PASS=your-email-password
EMAIL_FROM=noreply@campunity.com

# ── Cloudinary (optional — leave blank for local storage) ──
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
